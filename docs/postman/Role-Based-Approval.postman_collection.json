{
  "info": {
    "name": "Role-Based Approval API",
    "_postman_id": "2f5938ea-3305-4eeb-95f8-ea66b4abf77f",
    "description": "Postman collection for the Laravel role-based content approval workflow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "email",
      "value": "author@test.com"
    },
    {
      "key": "password",
      "value": "password"
    },
    {
      "key": "device_name",
      "value": "postman"
    },
    {
      "key": "post_id",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "Login",
      "request": {
        "auth": {
          "type": "noauth"
        },
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"device_name\": \"{{device_name}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "login"
          ]
        }
      }
    },
    {
      "name": "Logout",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/logout",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "logout"
          ]
        }
      }
    },
    {
      "name": "List Posts",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/posts",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "posts"
          ]
        }
      }
    },
    {
      "name": "Create Post",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Quarterly Product Update\",\n  \"body\": \"Release notes and roadmap details...\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/posts",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "posts"
          ]
        }
      }
    },
    {
      "name": "Update Post",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"Updated Title\",\n  \"body\": \"Updated post body\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/posts/{{post_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "posts",
            "{{post_id}}"
          ]
        }
      }
    },
    {
      "name": "Approve Post",
      "request": {
        "method": "POST",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/posts/{{post_id}}/approve",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "posts",
            "{{post_id}}",
            "approve"
          ]
        }
      }
    },
    {
      "name": "Reject Post",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"rejected_reason\": \"Please add references and supporting data.\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/posts/{{post_id}}/reject",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "posts",
            "{{post_id}}",
            "reject"
          ]
        }
      }
    },
    {
      "name": "Delete Post",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/posts/{{post_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "posts",
            "{{post_id}}"
          ]
        }
      }
    }
  ]
}
